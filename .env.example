# Backend API URL — used by the Vite frontend (src/lib/api.js)
# For local development, this defaults to http://localhost:8000 automatically.
# Uncomment and set this only if you need to override it locally.
# VITE_API_URL=http://localhost:8000

# For Vercel production, add this in:
# Vercel Dashboard → Your Project → Settings → Environment Variables
# VITE_API_URL=https://<your-railway-service>.up.railway.app
